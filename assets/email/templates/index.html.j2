<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Newsletter Style Gallery</title>
  <style>
    :root {
      --bg: #f2f5f9;
      --card: #ffffff;
      --text: #0f172a;
      --muted: #64748b;
      --line: #dbe2ea;
      --accent: #0b63ce;
      --accent-soft: #e8f2ff;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 20% 0%, #dbeafe 0%, transparent 40%),
        radial-gradient(circle at 80% 0%, #e2e8f0 0%, transparent 30%),
        var(--bg);
    }

    .wrap {
      max-width: 1360px;
      margin: 0 auto;
      padding: 28px;
    }

    h1 {
      margin: 0;
      font-size: 1.8rem;
    }

    .lead {
      margin: 8px 0 22px;
      color: var(--muted);
    }

    .grid {
      display: grid;
      gap: 16px;
      grid-template-columns: repeat(auto-fill, 640px);
      justify-content: center;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.06);
    }

    .card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 14px 16px;
      border-bottom: 1px solid var(--line);
      background: #f8fafc;
    }

    .card-header h2 {
      margin: 0;
      font-size: 1.02rem;
    }

    .card-header p {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 0.86rem;
    }

    .card-header .actions {
      display: flex;
      gap: 8px;
      flex-shrink: 0;
    }

    .btn {
      border: 1px solid #bcd6fa;
      color: var(--accent);
      text-decoration: none;
      padding: 8px 11px;
      border-radius: 8px;
      background: var(--accent-soft);
      font-weight: 600;
      font-size: 0.85rem;
    }

    .btn-flowing {
      border-color: #bbf7d0;
      color: #166534;
      background: #f0fdf4;
    }

    .previews {
      padding: 0;
      background: #fff;
    }

    .previews section {
      border: none;
      border-radius: 0;
      background: #fff;
      overflow: hidden;
    }

    .previews h3 {
      margin: 0;
      font-size: 0.8rem;
      padding: 7px 9px;
      color: var(--muted);
      border-bottom: 1px solid var(--line);
      background: #f8fafc;
    }

    iframe {
      width: 100%;
      min-width: 600px;
      height: 320px;
      border: 0;
      display: block;
      background: #fff;
    }

    @media (max-width: 900px) {
      .grid {
        grid-template-columns: 1fr;
      }
      .previews {
        grid-template-columns: 1fr;
        padding: 10px;
      }
    }
  </style>
</head>
<body>
  <main class="wrap">
    <h1>Newsletter Style Gallery</h1>
    <p class="lead">Each card previews the theme at fixed width (600 px, email-safe) and flowing (full window width).</p>
    <section class="grid">
      {% for card in cards %}
      <article class="card">
        <header class="card-header">
          <div>
            <h2>{{ card.title }}</h2>
            <p>{{ card.style_file }}</p>
          </div>
          <div class="actions">
            <a class="btn" href="{{ card.fixed_file }}" target="_blank" rel="noopener noreferrer">Open Fixed (600 px)</a>
            <a class="btn btn-flowing" href="{{ card.flowing_file }}" target="_blank" rel="noopener noreferrer">Open Flowing</a>
          </div>
        </header>
        <div class="previews">
          <section>
            <h3>Preview</h3>
            <iframe src="{{ card.fixed_file }}" title="{{ card.title }} preview"></iframe>
          </section>
        </div>
      </article>
      {% endfor %}
    </section>
  </main>
</body>
</html>
