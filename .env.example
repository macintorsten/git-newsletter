# SMTP Server Configuration
# Common providers:
#   Gmail:    smtp.gmail.com
#   Outlook:  smtp.office365.com
#   SendGrid: smtp.sendgrid.net
SMTP_SERVER=smtp.example.com

# SMTP Port (typically 587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP Authentication
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password_here

# Sender Email (optional, defaults to SMTP_USER if not set)
SENDER_EMAIL=your_email@example.com

# ⚠️  Security reminder: copy this file to ".env", fill in your real values,
# and never commit ".env" to version control — it is already listed in .gitignore.
